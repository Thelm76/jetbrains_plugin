<idea-plugin>
    <id>dev.sweet.assistant</id>
    <name>Sweet Autocomplete</name>
    <vendor email="support@sweet.dev" url="https://sweet.dev">Sweet AI</vendor>

    <description><![CDATA[
    OpenAI-compatible API powered Sweet autocomplete for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="java.xml">com.intellij.modules.java</depends>
    <depends optional="true" config-file="kotlin.xml">org.jetbrains.kotlin</depends>
    <depends optional="true" config-file="python.xml">com.intellij.modules.python</depends>
    <depends optional="true" config-file="typescript.xml">JavaScript</depends>
    <depends optional="true" config-file="cpp.xml">com.intellij.modules.cidr.lang</depends>
    <depends optional="true" config-file="ruby.xml">org.jetbrains.plugins.ruby</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="dev.sweet.assistant.startup.SweetStartupActivity"/>
        <notificationGroup id="Sweet Autocomplete" displayType="BALLOON"/>
        <notificationGroup id="Sweet Plugin Conflicts" displayType="BALLOON"/>
        <applicationService serviceImplementation="dev.sweet.assistant.settings.SweetSettings"/>
        <applicationService serviceImplementation="dev.sweet.assistant.settings.SweetMetaData"/>
        <projectConfigurable
                groupId="tools"
                displayName="Sweet Autocomplete"
                id="dev.sweet.assistant.settings.SweetSettingsConfigurable"
                instance="dev.sweet.assistant.settings.SweetSettingsConfigurable"/>
        <editorNotificationProvider implementation="dev.sweet.assistant.notifications.AutocompleteExclusionNotificationProvider"/>
        <statusBarWidgetFactory id="SweetAutocompleteStatus"
                                implementation="dev.sweet.assistant.statusbar.AutocompleteStatusBarWidgetFactory"/>
    </extensions>

    <actions>
        <action id="dev.sweet.assistant.autocomplete.edit.AcceptEditCompletionAction"
                class="dev.sweet.assistant.autocomplete.edit.AcceptEditCompletionAction"
                text="Accept Autocomplete Suggestion"
                description="Accept Autocomplete Suggestion">
            <keyboard-shortcut keymap="$default" first-keystroke="TAB"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="TAB"/>
        </action>
        <action id="dev.sweet.assistant.autocomplete.edit.RejectEditCompletionAction"
                class="dev.sweet.assistant.autocomplete.edit.RejectEditCompletionAction"
                text="Reject Autocomplete Suggestion"
                description="Reject Autocomplete Suggestion">
            <keyboard-shortcut keymap="$default" first-keystroke="ESCAPE"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="ESCAPE"/>
        </action>
        <action id="dev.sweet.assistant.autocomplete.edit.TriggerEditCompletionAction"
                class="dev.sweet.assistant.autocomplete.edit.TriggerEditCompletionAction"
                text="Trigger Autocomplete Suggestion"
                description="Request an autocomplete suggestion at the current caret position">
            <keyboard-shortcut keymap="$default" first-keystroke="alt I"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="alt I"/>
        </action>
        <action id="dev.sweet.assistant.autocomplete.edit.ClearAutocompleteRejectionCacheAction"
                class="dev.sweet.assistant.autocomplete.edit.ClearAutocompleteRejectionCacheAction"
                text="Show Last Rejected Suggestion"
                description="Undo cancellation and force a new autocomplete suggestion">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift BACK_SPACE"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="alt shift BACK_SPACE"/>
        </action>
    </actions>
</idea-plugin>
